# ── LLM Gateway (OpenAI-compatible) ──────────────────────────────────────────
LLM_BASE_URL=https://api.ai-gateway.tigeranalytics.com
LLM_API_KEY=sk-<YOUR-TIGER-ANALYTICS-GATEWAY-KEY-HERE>
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
MONGO_URL_FALLBACK=
DB_NAME=aigers_universe

# ── FastAPI / uvicorn ─────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8001
CORS_ORIGINS=*

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON_FORMAT=false

# ── FAISS vector store ─────────────────────────────────────────────────────────
FAISS_INDEX_PATH=./vectorstore/data/faiss_index

# ── HITL ───────────────────────────────────────────────────────────────────────
HITL_TIMEOUT_SECONDS=300
WORKFLOW_INPUT_RETENTION_DAYS=7
WORKFLOW_INPUT_MAX_FILES=6
WORKFLOW_INPUT_MAX_TOTAL_BYTES=52428800
WORKFLOW_INPUT_MAX_TEXT_CHARS=120000

JWT_SECRET=change-me-super-secret
JWT_EXPIRES_HOURS=12
ADMIN_EMAILS=your-admin-email@company.com
# Optional: fine-grained GitHub personal access token for private repo imports or higher rate limits.
# Create one from GitHub Settings > Developer settings > Personal access tokens > Fine-grained tokens.
# Grant read-only access to repository contents/metadata for the repos you want to import.
GITHUB_TOKEN=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
SERPAPI_KEY=...
OPENWEATHER_API_KEY=...
A2A_SHARED_SECRET=change-this-local-a2a-secret
A2A_PUBLIC_BASE_URL=http://localhost:8001
OFFICIAL_DOCS_MAX_RESULTS=5


